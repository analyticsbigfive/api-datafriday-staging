# Application
NODE_ENV=development
API_PORT=3000

# Database (Local Docker)
POSTGRES_USER=datafriday
POSTGRES_PASSWORD=datafriday_password
POSTGRES_DB=datafriday
POSTGRES_PORT=5432

# Prisma Database URL
# Pour développement local avec Docker:
DATABASE_URL="postgresql://datafriday:datafriday_password@localhost:5432/datafriday?schema=public"

# Pour Supabase (production):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase (optionnel, si vous utilisez les fonctionnalités Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT & Auth (à configurer selon vos besoins)
JWT_SECRET=your-jwt-secret-change-this
JWT_EXPIRATION=7d
