# ==========================================
# PRODUCTION - Supabase Configuration
# ==========================================

NODE_ENV=production
API_PORT=3000
PORT=3000

# ==========================================
# Supabase Database
# ==========================================

# Connection Pooler (RECOMMANDÉ pour production)
# Dashboard Supabase → Settings → Database → Connection string → URI
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Alternative: Direct Connection (moins performant)
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ==========================================
# Supabase Auth & Storage (Optionnel)
# ==========================================

# Dashboard Supabase → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Supabase CLI (pour migrations)
# Dashboard → Settings → General → Reference ID
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
# Dashboard → Settings → Database → Database Password
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD
# Access Token (https://app.supabase.com/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_your_access_token_here

# ==========================================
# Security
# ==========================================

# JWT Secret — MUST match the Supabase project JWT secret (HS256, legacy)
# ⚠️  Do NOT generate a random key here — use the Supabase project secret
# Dashboard Supabase → Project Settings → API → "JWT Secret"
JWT_SECRET=your-supabase-project-jwt-secret
JWT_EXPIRES_IN=7d

# JWT verification mode (optional).
#  - Leave unset → symmetric HS256 with JWT_SECRET above (backward compatible).
#  - Set SUPABASE_JWKS_URI to verify asymmetric (RS256/ES256) tokens via JWKS,
#    ready for Supabase's rotating signing keys.
#  - Or set JWT_USE_JWKS=true to auto-derive the JWKS URI from SUPABASE_URL.
# JWT_USE_JWKS=true
# SUPABASE_JWKS_URI=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# Where invited users land after clicking the Supabase invitation email.
# Must be added to Supabase → Authentication → URL Configuration → Redirect URLs.
# Points to the front "accept invite" page where the user sets their password.
INVITE_REDIRECT_URL=https://app.yourdomain.com/accept-invite

# Encryption key for sensitive data (32 bytes = 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS Origins (domaines autorisés, séparés par virgule)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGIN=*

# ==========================================
# Logging & Monitoring
# ==========================================

LOG_LEVEL=info
ENABLE_LOGGING=true

# ==========================================
# Rate Limiting
# ==========================================

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

WEEZEVENT_CLIENT_ID=your_weezevent_client_id
WEEZEVENT_CLIENT_SECRET=your_weezevent_client_secret
