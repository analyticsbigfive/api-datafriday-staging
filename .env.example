# ==========================================
# PRODUCTION - Supabase Configuration
# ==========================================

NODE_ENV=production
API_PORT=3000

# ==========================================
# Supabase Database
# ==========================================

# Connection Pooler (RECOMMANDÉ pour production)
# Dashboard Supabase → Settings → Database → Connection string → URI
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Alternative: Direct Connection (moins performant)
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ==========================================
# Supabase Auth & Storage (Optionnel)
# ==========================================

# Dashboard Supabase → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Supabase CLI (pour migrations)
# Dashboard → Settings → General → Reference ID
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
# Dashboard → Settings → Database → Database Password
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# ==========================================
# Security
# ==========================================

# JWT Secret (générer avec: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origins (domaines autorisés, séparés par virgule)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ==========================================
# Logging & Monitoring
# ==========================================

LOG_LEVEL=info
ENABLE_LOGGING=true

# ==========================================
# Rate Limiting
# ==========================================

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
