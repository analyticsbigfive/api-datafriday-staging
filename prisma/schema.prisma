// Datasource Supabase Postgres
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== ENUMS ====================

enum ElementType {
  access
  hospitality
  entertainment
  shop
  merchshop
  entrance
  storage
  kitchen
  fnb_food
  fnb_beverages
  fnb_bar
  fnb_snack
  fnb_icecream
  seating
  stage
  parking
  restroom
  office
  other
}

enum GoodType {
  Food
  Beverage
  Packaging
  Other
}

enum StorageType {
  Cold
  Dry
  Frozen
}

enum Diet {
  Vegetarian
  Vegan
  GlutenFree
  Halal
  Kosher
}


enum ComponentCategory {
  Sauce
  Condiment
  Topping
  Base
  Filling
  Other
}

enum IngredientCategory {
  Vegetable
  Meat
  Fish
  Dairy
  Bread
  Spice
  Condiment
  Grain
  Fruit
  Herb
  Oil
  Sweetener
  Beverage
  Packaging
  Other
}

enum AccessType {
  venueentrance
  emergency
  service
  vip
}

enum HospitalityType {
  salon
  lounge
  restaurant
  bar
  vip_area
}

enum EntertainmentType {
  sportground
  stage
  screen
  playground
}

enum ShopType {
  food
  beverages
  beer
  merchandise
  souvenirs
  retail
}

enum EntranceType {
  public
  vip
  service
  emergency
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

// ==================== MULTI-TENANT ====================

model Tenant {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique
  domain String?      @unique
  logo   String?
  plan   TenantPlan   @default(FREE)
  status TenantStatus @default(ACTIVE)

  // Invitation System
  invitationCode    String? @unique // Code for joining this tenant
  invitationEnabled Boolean @default(true) // Allow new members to join

  // Business Information
  organizationType String? // Restaurant, Hotel, Bar, Event, etc.
  siret            String?
  address          String?
  city             String?
  postalCode       String?
  country          String? @default("France")
  email            String?
  phone            String?

  // Additional Info
  numberOfEmployees Int?
  numberOfSpaces    Int?
  paymentMethod     String? // Card, Transfer, Direct Debit, etc.

  metadata Json?

  // Weezevent Integration
  weezeventClientId       String?
  weezeventClientSecret   String? // Encrypted
  weezeventOrganizationId String? // Weezevent Organization ID
  weezeventEnabled        Boolean @default(false)

  // Weezevent Webhook
  weezeventWebhookSecret  String? // Secret for signature validation
  weezeventWebhookEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users       User[] // Keep for backward compatibility
  userTenants UserTenant[] // New many-to-many relation
  spaces      Space[]
  suppliers   Supplier[]

  // Menu domain relations (ajoutées pour isolation multi-tenant)
  menuItems      MenuItem[]
  menuComponents MenuComponent[]
  ingredients    Ingredient[]
  packagings     Packaging[]
  marketPrices   MarketPrice[]
  csvMappings    CsvMapping[]
  menus          Menu[]
  auditLogs      AuditLog[]
  webhooks       Webhook[]

  // Weezevent Relations
  weezeventEvents           WeezeventEvent[]
  weezeventMerchants        WeezeventMerchant[]
  weezeventLocations        WeezeventLocation[]
  weezeventProducts         WeezeventProduct[]
  weezeventUsers            WeezeventUser[]
  weezeventWallets          WeezeventWallet[]
  weezeventTransactions     WeezeventTransaction[]
  weezeventWebhookEvents    WeezeventWebhookEvent[]
  weezeventProductMappings  WeezeventProductMapping[]
  weezeventProductVariants  WeezeventProductVariant[]
  weezeventProductComponents WeezeventProductComponent[]
  weezeventOrders           WeezeventOrder[]
  weezeventPrices           WeezeventPrice[]
  weezeventAttendees        WeezeventAttendee[]
  weezeventIntegrations     WeezeventIntegration[]

  @@index([slug])
  @@index([status])
  @@index([weezeventEnabled])
  @@index([weezeventWebhookEnabled])
}

// Multiple Weezevent API credentials per tenant (one per event / organization)
model WeezeventIntegration {
  id             String   @id @default(cuid())
  tenantId       String
  name           String // User-defined label, e.g. "Stande", "Hellfest 2025"
  clientId       String
  clientSecret   String // Encrypted
  organizationId String? // Weezevent Organization ID
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enabled])
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

// ==================== USER & AUTH ====================

model User {
  id        String  @id @default(cuid())
  email     String
  firstName String
  lastName  String
  fullName  String?

  role      UserRole @default(VIEWER)
  avatar    String?
  tenantId  String // Keep for backward compatibility
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenants  UserTenant[] // New many-to-many relation
  pinnedSpaces UserPinnedSpace[]
  spaceAccess  UserSpaceAccess[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
}

// Many-to-many relation between User and Tenant
model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole @default(ADMIN)
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([isOwner])
}

model UserPinnedSpace {
  id       String   @id @default(cuid())
  userId   String
  spaceId  String
  pinnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([userId])
}

model UserSpaceAccess {
  id        String   @id @default(cuid())
  userId    String
  spaceId   String
  role      UserRole @default(VIEWER)
  grantedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([userId])
  @@index([spaceId])
}

// ==================== SPACE & CONFIG ====================

model Space {
  id        String   @id @default(cuid())
  name      String
  image     String?  @db.Text
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contact Info
  tel               String?
  email             String?
  contactTel        String?
  contactEmail      String?
  mainContactPerson String?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  postcode     String?
  department   Int?
  country      String?

  // Space Details
  spaceType      String? // Stadium, Arena, etc.
  spaceTypeOther String?
  maxCapacity    Int?
  homeTeam       String?

  // Social Media
  facebook  String?
  instagram String?
  twitter   String?
  tiktok    String?

  // Metrics (calculated/cached)
  avgEvent       Float?
  avgTransaction Float?
  perCapita      Float?
  cachedMetrics  Json? // Cache des métriques calculées
  
  // Timezone for dashboard aggregations
  timezone       String? @default("Europe/Paris")

  // Relations
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  configs       Config[]
  pinnedByUsers UserPinnedSpace[]
  userAccess    UserSpaceAccess[]
  menus         Menu[]

  @@index([tenantId])
  @@index([name])
  @@index([spaceType])
  @@index([city])
}

model Config {
  id        String   @id @default(cuid())
  name      String
  spaceId   String
  capacity  Int?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  floors    Floor[]
  forecourt Forecourt?
  stations  Station[]

  @@index([spaceId])
}

// ==================== FLOOR & ELEMENTS ====================

model Floor {
  id           String @id @default(cuid())
  configId     String
  name         String
  level        Int
  width        Float
  height       Float
  length       Float
  cornerRadius Json?

  config   Config         @relation(fields: [configId], references: [id], onDelete: Cascade)
  elements SpaceElement[]

  @@index([configId])
  @@index([level])
}

// ==================== UNIFIED SPACE ELEMENT ====================
// Polymorphic: belongs to either a Floor or a Forecourt (one must be set)

model SpaceElement {
  id          String      @id @default(cuid())
  floorId     String?     // FK to Floor (if element is inside a floor)
  forecourtId String?     // FK to Forecourt (if element is in forecourt)
  name        String
  type        ElementType
  x           Float
  y           Float
  depth       Float?
  width       Float?
  height      Float?
  height3d    Float?      // Hauteur 3D en mètres
  rotation    Float?      @default(0)
  image       String?     @db.Text
  notes       String?
  capacity    Int?

  // Corner radius pour forme arrondie
  cornerRadiusTL Float? @default(0)
  cornerRadiusTR Float? @default(0)
  cornerRadiusBL Float? @default(0)
  cornerRadiusBR Float? @default(0)

  // Type-specific attributes (arrays stockés en JSON)
  shopTypes          String[]
  storageTypes       String[]
  hospitalityTypes   String[]
  accessTypes        String[]
  entertainmentTypes String[]
  entranceTypes      String[]
  kitchenTypes       String[]

  attributes Json?
  tags       String[]

  // Relations
  floor          Floor?               @relation(fields: [floorId], references: [id], onDelete: Cascade)
  forecourt      Forecourt?           @relation(fields: [forecourtId], references: [id], onDelete: Cascade)
  performance     ElementPerformance?
  staffPositions  ElementStaff[]
  inventoryItems  ElementInventory[]
  menuAssignments MenuAssignment[]

  @@index([floorId])
  @@index([forecourtId])
  @@index([type])
}

// ==================== ELEMENT PERFORMANCE ====================

model ElementPerformance {
  id                    String   @id @default(cuid())
  elementId             String   @unique
  revenue               Float?   @default(0)
  numberOfPOS           Int?     @default(0)
  numberOfTransactions  Float?   @default(0)
  transactionsPerMinute Float?   @default(0)
  staffCost             Float?   @default(0)
  revenuePerEmployee    Float?   @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  element SpaceElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
}

// ==================== ELEMENT STAFF ====================

model ElementStaff {
  id         String   @id @default(cuid())
  elementId  String
  position   String   // "Cashier", "Cook", "Security", etc.
  count      Int      @default(1)
  hourlyRate Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  element SpaceElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([elementId])
}

// ==================== ELEMENT INVENTORY ====================

model ElementInventory {
  id         String   @id @default(cuid())
  elementId  String
  name       String
  quantity   Float    @default(0)
  unit       String?  // "units", "kg", "liters", etc.
  minStock   Float?   // Niveau minimum d'alerte
  maxStock   Float?   // Capacité maximum
  isCustom   Boolean  @default(true)
  menuItemId String?  // Référence optionnelle à un item du menu
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  element SpaceElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([elementId])
  @@index([name])
}

model Forecourt {
  id       String @id @default(cuid())
  configId String @unique
  name     String
  width    Float
  length   Float

  config   Config         @relation(fields: [configId], references: [id], onDelete: Cascade)
  elements SpaceElement[]
}

// ==================== SUPPLIER & MARKET PRICES ====================

model Supplier {
  id               String   @id @default(cuid())
  name             String
  email            String?
  tel              String?
  city             String?
  address          String?
  postcode         String?
  picture          String?
  sites            String[] // Array of spaceIds
  contactName      String?
  configurationIds String[] @default([])
  sectors          String[] @default([])
  tenantId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketPrices MarketPrice[]

  @@index([tenantId])
  @@index([name])
}

model MarketPrice {
  id                     String   @id @default(cuid())
  unit                   String
  image                  String?
  price                  Decimal  @db.Decimal(10, 2)
  goodType               GoodType
  itemName               String
  category               String?
  supplierItem           String?
  recipeUnit             String?
  purchaseUnitConversion Float?
  supplier               String? // Nom du fournisseur
  supplierId             String? // ID du fournisseur
  pricePerUnit           Decimal? @db.Decimal(10, 4)
  packedUnits            Int?
  numberOfUnits          Int?
  unitsPerPurchase       Int?
  packingWidth           Float?
  packingHeight          Float?
  packingLength          Float?
  tenantId               String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  deletedAt              DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierRel Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  ingredients Ingredient[]
  packagings  Packaging[]

  @@index([tenantId])
  @@index([supplierId])
  @@index([goodType])
  @@index([itemName])
  @@index([category])
}

// ==================== WEEZEVENT SYNC ====================

model WeezeventEvent {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // Event data
  name           String
  organizationId String
  startDate      DateTime?
  endDate        DateTime?
  description    String?
  location       String?
  capacity       Int?
  status         String?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions WeezeventTransaction[]
  locations    WeezeventLocation[]
  orders       WeezeventOrder[]
  prices       WeezeventPrice[]
  attendees    WeezeventAttendee[]

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
  @@index([startDate])
}

model WeezeventMerchant {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // Merchant data
  name           String
  organizationId String
  description    String?
  email          String?
  phone          String?
  address        Json?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions WeezeventTransaction[]

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
}

model WeezeventLocation {
  id          String  @id @default(cuid())
  weezeventId String
  tenantId    String
  eventId     String?

  // Location data
  name        String
  type        String?
  capacity    Int?
  coordinates Json?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event        WeezeventEvent?        @relation(fields: [eventId], references: [id])
  transactions WeezeventTransaction[]

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
  @@index([eventId])
}

model WeezeventProduct {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // Product data
  name        String
  description String?
  category    String?
  basePrice   Decimal? @db.Decimal(10, 2)
  vatRate     Decimal? @db.Decimal(5, 2)
  image       String?
  allergens   String[]

  // Composition
  isCompound Boolean @default(false)
  components Json?
  variants   Json?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionItems WeezeventTransactionItem[]
  mappings         WeezeventProductMapping[]
  productVariants  WeezeventProductVariant[]
  productComponents WeezeventProductComponent[]
  prices           WeezeventPrice[]

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
  @@index([category])
}

model WeezeventUser {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // User data (Client)
  email     String?
  firstName String?
  lastName  String?
  phone     String?
  birthdate DateTime?
  address   Json?

  // Wallet
  walletId String?

  // GDPR
  gdprConsent      Boolean @default(false)
  marketingConsent Boolean @default(false)

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wallet WeezeventWallet? @relation(fields: [walletId], references: [id])

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
  @@index([email])
}

model WeezeventWallet {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // Wallet data
  balance       Decimal @db.Decimal(10, 2)
  currency      String
  userId        String?
  walletGroupId String?
  status        String

  // Card info
  cardNumber String?
  cardType   String?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users              WeezeventUser[]
  sellerTransactions WeezeventTransaction[] @relation("SellerWallet")

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([weezeventId])
  @@index([userId])
}

model WeezeventTransaction {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  // Transaction data
  amount          Decimal  @db.Decimal(10, 2)
  status          String
  transactionDate DateTime

  // Event and merchant info
  eventId      String?
  eventName    String?
  merchantId   String?
  merchantName String?
  locationId   String?
  locationName String?

  // Seller info
  sellerId       String?
  sellerWalletId String?

  // Metadata
  metadata Json?
  rawData  Json

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  // Relations
  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event        WeezeventEvent?            @relation(fields: [eventId], references: [id])
  merchant     WeezeventMerchant?         @relation(fields: [merchantId], references: [id])
  location     WeezeventLocation?         @relation(fields: [locationId], references: [id])
  sellerWallet WeezeventWallet?           @relation("SellerWallet", fields: [sellerWalletId], references: [id])
  items        WeezeventTransactionItem[]

  @@index([tenantId])
  @@index([weezeventId])
  @@index([eventId])
  @@index([merchantId])
  @@index([locationId])
  @@index([status])
  @@index([transactionDate])
  @@index([syncedAt])
  @@index([sellerWalletId]) // Added walletId index
  // Composite indexes for analytics
  @@index([tenantId, status, transactionDate])
  @@unique([tenantId, weezeventId])
  @@index([tenantId, eventId, status])
  @@index([eventId, transactionDate])
}

// ==================== WEEZEVENT SYNC STATE ====================

// Track sync state per tenant/type for incremental sync
model WeezeventSyncState {
  id       String @id @default(cuid())
  tenantId String
  syncType String // 'events', 'transactions', 'products', 'wallets', 'users'

  // Cursor-based sync (most efficient)
  lastSyncedAt    DateTime? // Last successful sync time
  lastCursor      String? // API cursor for pagination
  lastWeezeventId String? // Last processed Weezevent ID
  lastUpdatedAt   DateTime? // Last 'updated_at' from API

  // Stats
  totalSynced       Int     @default(0)
  lastSyncCount     Int     @default(0)
  lastSyncDuration  Int? // Duration in ms
  lastError         String?
  consecutiveErrors Int     @default(0)

  // Checkpoints for large syncs
  checkpoint Json? // Store progress for resumable syncs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, syncType])
  @@index([tenantId])
  @@index([syncType])
  @@index([lastSyncedAt])
}

// ==================== WEEZEVENT WEBHOOK ====================

model WeezeventWebhookEvent {
  id       String @id @default(cuid())
  tenantId String

  // Webhook data
  eventType String // transaction, refill, transfer, wallet
  method    String // create, update, delete
  payload   Json // Full webhook body
  signature String? // X-Weezevent-Signature header

  // Processing
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  retryCount  Int       @default(0)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
}

model WeezeventTransactionItem {
  id              String  @id @default(cuid())
  transactionId   String
  weezeventItemId String?

  // Item data
  productId   String?
  productName String?
  compoundId  String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  vat         Decimal @db.Decimal(5, 2)
  reduction   Decimal @default(0) @db.Decimal(5, 2)

  // Metadata
  rawData Json

  // Audit
  createdAt DateTime @default(now())

  // Relations
  transaction WeezeventTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     WeezeventProduct?    @relation(fields: [productId], references: [id])
  payments    WeezeventPayment[]

  @@index([transactionId])
  @@index([productId])
  @@index([weezeventItemId])
  // Composite index for product analytics
  @@index([productId, transactionId])
}

model WeezeventPayment {
  id                 String  @id @default(cuid())
  itemId             String
  weezeventPaymentId String?

  // Payment data
  walletId        String?
  amount          Decimal @db.Decimal(10, 2)
  amountVat       Decimal @db.Decimal(10, 2)
  currencyId      String?
  quantity        Int
  paymentMethodId String?

  // Metadata
  rawData Json

  // Audit
  createdAt DateTime @default(now())

  // Relations
  item WeezeventTransactionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([walletId])
}

// ==================== WEEZEVENT PRODUCT MAPPING ====================

model WeezeventProductMapping {
  id                 String   @id @default(cuid())
  tenantId           String
  weezeventProductId String
  menuItemId         String
  autoMapped         Boolean  @default(false)
  confidence         Float?
  mappedBy           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  weezeventProduct WeezeventProduct @relation(fields: [weezeventProductId], references: [id], onDelete: Cascade)
  menuItem         MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([weezeventProductId])
  @@index([menuItemId])
  @@index([tenantId])
  @@index([autoMapped])
}

model WeezeventProductVariant {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String
  productId   String

  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  sku         String?
  stock       Int?
