  event  WeezeventEvent? @relation(fields: [eventId], references: [id])

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([eventId])
  @@index([weezeventId])
  @@index([orderDate])
  @@index([status])
}

model WeezeventPrice {
  id          String @id @default(cuid())
  weezeventId String
  tenantId    String

  eventId     String?
  productId   String?
  name        String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String
  validFrom   DateTime?
  validUntil  DateTime?
  priceType   String?

  metadata Json?
  rawData  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event   WeezeventEvent?  @relation(fields: [eventId], references: [id])
  product WeezeventProduct? @relation(fields: [productId], references: [id])

  @@unique([tenantId, weezeventId])
  @@index([tenantId])
  @@index([eventId])
  @@index([productId])
  @@index([weezeventId])
