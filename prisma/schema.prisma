// ==================== INGREDIENTS & PACKAGING ====================

model Ingredient {
  id                         String              @id @default(cuid())
  name                       String
  active                     Boolean             @default(true)
  supplier                   String?
  recipeUnit                 String
  storageType                StorageType?
  purchaseUnit               String
  marketPriceId              String?
  costPerRecipeUnit          Decimal?            @db.Decimal(10, 4)
  ingredientCategory         IngredientCategory?
  costPerPurchaseUnit        Decimal?            @db.Decimal(10, 4)
  purchaseUnitsPerRecipeUnit Float?
  tenantId                   String
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  deletedAt                  DateTime?

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketPrice          MarketPrice?          @relation(fields: [marketPriceId], references: [id], onDelete: SetNull)
  componentIngredients ComponentIngredient[]
  menuItemIngredients  MenuItemIngredient[]

  @@index([tenantId])
  @@index([name])
  @@index([active])
  @@index([ingredientCategory])
}

model Packaging {
  id                         String       @id @default(cuid())
  name                       String
  active                     Boolean      @default(true)
  supplier                   String?
  recipeUnit                 String
  storageType                StorageType?
  purchaseUnit               String
  marketPriceId              String?
  costPerRecipeUnit          Decimal?     @db.Decimal(10, 4)
  ingredientCategory         String?
  costPerPurchaseUnit        Decimal?     @db.Decimal(10, 4)
  purchaseUnitsPerRecipeUnit Float?
  tenantId                   String
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  deletedAt                  DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marketPrice        MarketPrice?        @relation(fields: [marketPriceId], references: [id], onDelete: SetNull)
  menuItemPackagings MenuItemPackaging[]

  @@index([tenantId])
  @@index([name])
  @@index([active])
}

// ==================== MENU COMPONENTS ====================

model MenuComponent {
  id                  String       @id @default(cuid())
  name                String
  unit                String
  category            String // Flexible pour "Food", "Sauce", etc.
  unitCost            Decimal?     @db.Decimal(10, 4)
  allergens           String[]
  description         String?
  storageType         StorageType?
  subComponents       Json? // Pour stocker les subComponents JSON de Figma
  componentCategory   String? // "Veg", "Sauce", etc.
  numberOfUnitsRecipe Int? // Nombre d'unités par recette
  tenantId            String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients ComponentIngredient[]
  children    ComponentComponent[]  @relation("ParentToChild")
  parents     ComponentComponent[]  @relation("ChildToParent")
  usedIn      MenuItemComponent[]

  @@index([tenantId])
  @@index([name])
  @@index([category])
}

model ComponentIngredient {
  id           String   @id @default(cuid())
  componentId  String
  ingredientId String
  quantity     Float
  unit         String?
  unitCost     Decimal? @db.Decimal(10, 4)
  cost         Decimal? @db.Decimal(10, 4)

  component  MenuComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  ingredient Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([componentId, ingredientId])
  @@index([componentId])
  @@index([ingredientId])
}

model ComponentComponent {
  id       String   @id @default(cuid())
  parentId String
  childId  String
  quantity Float
  unit     String?
  cost     Decimal? @db.Decimal(10, 4)

  parent MenuComponent @relation("ParentToChild", fields: [parentId], references: [id], onDelete: Cascade)
  child  MenuComponent @relation("ChildToParent", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

// ==================== MENU ITEMS ====================

// ==================== PRODUCT CLASSIFICATION ====================

// Types dynamiques de produits (Beverage, Food, Combo, Glasses, Ticket/Bracelets...)
model ProductType {
  id        String   @id @default(cuid())
  name      String
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories ProductCategory[]
  menuItems  MenuItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([name])
}

// Catégories dynamiques de produits (Beer, Soft Drink, Main, Desert...)
model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  typeId    String
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type      ProductType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]

  @@unique([tenantId, typeId, name])
  @@index([tenantId])
  @@index([typeId])
  @@index([name])
}

// ==================== MENU ITEMS ====================

model MenuItem {
  id                   String        @id @default(cuid())
  name                 String
  typeId               String        // FK to ProductType (required)
  categoryId           String        // FK to ProductCategory (required)
  diet                 Diet[]
  allergens            String[]
  picture              String?
  basePrice            Decimal       @db.Decimal(10, 2)
  totalCost            Decimal?      @db.Decimal(12, 4)
  margin               Float?
  description          String?
  storageType          StorageType[]
  readyForSale         String?       // "Yes", "No" ou null
  comboItem            String?       // "Yes", "No" ou null
  numberOfPiecesRecipe Int?
  componentsData       Json?         // Pour stocker les components JSON de Figma
  tenantId             String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productType       ProductType               @relation(fields: [typeId], references: [id])
  productCategory   ProductCategory           @relation(fields: [categoryId], references: [id])
  components        MenuItemComponent[]
  ingredients       MenuItemIngredient[]
  packagings        MenuItemPackaging[]
  menuAssignments   MenuAssignment[]
  weezeventMappings WeezeventProductMapping[]

  @@index([tenantId])
  @@index([name])
  @@index([typeId])
  @@index([categoryId])
  @@index([readyForSale])
}

model MenuItemComponent {
  id            String       @id @default(cuid())
  menuItemId    String
  componentId   String
  numberOfUnits Float
  unitCost      Decimal?     @db.Decimal(10, 4)
  totalCost     Decimal?     @db.Decimal(12, 4)
  storageType   StorageType?

  menuItem  MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  component MenuComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, componentId])
  @@index([menuItemId])
  @@index([componentId])
}

model MenuItemIngredient {
  id            String       @id @default(cuid())
  menuItemId    String
  ingredientId  String
  numberOfUnits Float
  unitCost      Decimal?     @db.Decimal(10, 4)
  totalCost     Decimal?     @db.Decimal(12, 4)
  storageType   StorageType?

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
}

model MenuItemPackaging {
  id            String       @id @default(cuid())
  menuItemId    String
  packagingId   String
  numberOfUnits Float
  unitCost      Decimal?     @db.Decimal(10, 4)
  totalCost     Decimal?     @db.Decimal(12, 4)
  storageType   StorageType?

  menuItem  MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  packaging Packaging @relation(fields: [packagingId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, packagingId])
  @@index([menuItemId])
  @@index([packagingId])
}

// ==================== STATIONS & MENU ASSIGNMENTS ====================

model Station {
  id        String   @id // Garder les IDs comme "1761836020929"
  configId  String
  name      String? // Nom optionnel
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config Config           @relation(fields: [configId], references: [id], onDelete: Cascade)
  menus  MenuAssignment[]

  @@index([configId])
}

model MenuAssignment {
  id         String   @id @default(cuid())
  stationId  String?  // Optional: assignment to a station
  elementId  String?  // Optional: assignment to a space element
  menuItemId String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  station  Station?      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  element  SpaceElement? @relation(fields: [elementId], references: [id], onDelete: Cascade)
  menuItem MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([stationId, menuItemId])
  @@unique([elementId, menuItemId])
  @@index([stationId])
  @@index([elementId])
  @@index([menuItemId])
}

// ==================== OUTBOUND WEBHOOKS ====================

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  url       String   // Target URL
  secret    String?  // HMAC signing secret
  events    String[] // e.g. ["menu_item.created", "menu_item.updated"]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs   WebhookLog[]

  @@index([tenantId])
  @@index([active])
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String   // e.g. "menu_item.created"
  payload    Json
  status     Int      // HTTP status code of the response
  response   String?  // Response body (truncated)
  duration   Int?     // Response time in ms
  success    Boolean
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([createdAt])
}

// ==================== CSV MAPPINGS ====================

model CsvMapping {
  id          String   @id @default(cuid())
  mappingType String
  mapping     Json
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([mappingType])
}

// ==================== EVENTS (Internal Planning) ====================

// Types d'événements (Concert, Sport Match, Conference...)
model EventType {
  id        String   @id @default(uuid())
  name      String
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories EventCategory[]
  events     Event[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([name])
}

// Catégories d'événements (Show, Ligue 1, Festival...)
model EventCategory {
  id          String   @id @default(uuid())
  name        String
  eventTypeId String
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventType     EventType          @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  subcategories EventSubcategory[]
  events        Event[]

  @@unique([tenantId, eventTypeId, name])
  @@index([tenantId])
  @@index([eventTypeId])
  @@index([name])
}

// Sous-catégories d'événements (Communautaire, International, Régional...)
model EventSubcategory {
  id              String   @id @default(uuid())
  name            String
  eventCategoryId String
  tenantId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  eventCategory EventCategory @relation(fields: [eventCategoryId], references: [id], onDelete: Cascade)
  events        Event[]

  @@unique([tenantId, eventCategoryId, name])
  @@index([tenantId])
  @@index([eventCategoryId])
  @@index([name])
}

// Événements planifiés
model Event {
  id                 String   @id @default(uuid())
  name               String
  eventDate          DateTime
  spaceId            String?
  configurationId    String?
  eventTypeId        String?
  eventCategoryId    String?
  eventSubcategoryId String?
  tenantId           String?

  // Event details
  location         String?
  spaceName        String?
  sessions         String? // "Open/Show" info
  numberOfSessions Int?
  hasOpeningAct    Boolean?
  hasIntermission  Boolean?

  // Revenue tracking (calculated)
  revenue          Decimal? @db.Decimal(12, 2)
  transactionCount Int?
  avgSpendPerTx    Decimal? @db.Decimal(10, 2)
  perCapita        Decimal? @db.Decimal(10, 2)

  // Status
  status       String? // "success", "pending", etc.
  calculatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  eventType        EventType?        @relation(fields: [eventTypeId], references: [id])
  eventCategory    EventCategory?    @relation(fields: [eventCategoryId], references: [id])
  eventSubcategory EventSubcategory? @relation(fields: [eventSubcategoryId], references: [id])

  @@index([tenantId])
  @@index([spaceId])
  @@index([eventDate])
  @@index([eventTypeId])
  @@index([eventCategoryId])
  @@index([eventSubcategoryId])
}

// ==================== AUDIT TRAIL ====================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  action    String   // CREATE, UPDATE, DELETE, RESTORE
  entity    String   // MenuItem, MenuComponent, etc.
  entityId  String
  changes   Json?    // { before: {...}, after: {...} }
  metadata  Json?    // Extra context (IP, user-agent, etc.)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, createdAt])
  @@index([tenantId, entityId])
  @@index([userId])
}

// ==================== MENU (dédié) ====================

model Menu {
  id          String   @id @default(cuid())
  name        String
  description String?
  spaceId     String
  configId    String
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([spaceId, configId, name])
  @@index([tenantId])
  @@index([spaceId])
  @@index([configId])
}

// ==================== SPACE DASHBOARD - MAPPING DOMAIN ====================

// Maps Weezevent Location to Space for revenue attribution
model WeezeventLocationSpaceMapping {
  id                   String   @id @default(cuid())
  tenantId             String
  weezeventLocationId  String
  spaceId              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([tenantId, weezeventLocationId])
  @@index([tenantId, spaceId])
  @@index([weezeventLocationId])
}

// Maps Weezevent Merchant to SpaceElement (shop) for revenue grouping
model WeezeventMerchantElementMapping {
  id                  String   @id @default(cuid())
  tenantId            String
  weezeventMerchantId String
  spaceElementId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, weezeventMerchantId])
  @@index([tenantId, spaceElementId])
  @@index([weezeventMerchantId])
}

// Tenant-specific VAT configuration
model TenantVatConfig {
  id             String   @id @default(cuid())
  tenantId       String
  defaultVatRate Decimal  @db.Decimal(5, 2)
  countryCode    String   @default("FR")
  effectiveFrom  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, effectiveFrom])
  @@index([tenantId])
}

// ==================== SPACE DASHBOARD - READ MODELS ====================

// Daily revenue aggregates by space, with optional dimensions
model SpaceRevenueDailyAgg {
  id                  String   @id @default(cuid())
  tenantId            String
  spaceId             String
  day                 DateTime @db.Date
  timezone            String   @default("Europe/Paris")
  
  // Optional dimensions for filtering
  weezeventEventId    String?
  weezeventLocationId String?
  weezeventMerchantId String?
  spaceElementId      String?
  
  // Aggregated metrics
  revenueHt           Decimal  @db.Decimal(12, 2)
  transactionsCount   Int
  itemsCount          Int
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, spaceId, day, weezeventEventId, weezeventLocationId, weezeventMerchantId, spaceElementId])
  @@index([tenantId, spaceId, day])
  @@index([tenantId, spaceId, spaceElementId, day])
  @@index([tenantId, spaceId, weezeventLocationId, day])
  @@index([tenantId, spaceId, weezeventMerchantId, day])
  @@index([tenantId, spaceId, weezeventEventId, day])
}

// Daily product revenue aggregates
model SpaceProductRevenueDailyAgg {
  id                 String   @id @default(cuid())
  tenantId           String
  spaceId            String
  day                DateTime @db.Date
  weezeventProductId String
  
  // Aggregated metrics
  revenueHt          Decimal  @db.Decimal(12, 2)
  quantity           Int
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, spaceId, day, weezeventProductId])
  @@index([tenantId, spaceId, day])
  @@index([tenantId, spaceId, weezeventProductId, day])
}

// Version tracking for cache invalidation
model SpaceDashboardVersion {
  spaceId   String   @id
  tenantId  String
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== SPACE DASHBOARD - JOB TRACKING ====================

// Tracks aggregation job execution for monitoring and retry
model AggregationJobLog {
  id                   String    @id @default(cuid())
  tenantId             String
  spaceId              String?
  jobType              String    // 'full' | 'incremental' | 'rebuild'
  status               String    // 'pending' | 'running' | 'completed' | 'failed'
  fromDate             DateTime  @db.Date
  toDate               DateTime  @db.Date
  transactionsProcessed Int      @default(0)
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  error                String?   @db.Text
  retryCount           Int       @default(0)
  metadata             Json?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([tenantId, status, startedAt])
  @@index([spaceId, status])
  @@index([status, startedAt])
}

// Tracks unmapped Weezevent entities for data quality monitoring
model UnmappedDataMetrics {
  id               String   @id @default(cuid())
  tenantId         String
  entityType       String   // 'location' | 'merchant' | 'product'
  entityId         String
  entityName       String
  transactionCount Int      @default(0)
  revenueHt        Decimal  @db.Decimal(12, 2)
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @updatedAt
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, entityType])
  @@index([lastSeenAt])
}
